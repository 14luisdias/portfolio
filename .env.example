# ==============================================================================
# Exemplo de variáveis de ambiente.
# Copie para .env e preencha os valores. NUNCA comite .env / .env.local.
# ==============================================================================

# ---- Banco de dados (PostgreSQL) --------------------------------------------
# Dev local (Postgres na máquina, app FORA do Docker):
DATABASE_URL="postgresql://portfolio:SENHA@localhost:5432/portfolio_dev?schema=public"

# Dev com a app DENTRO do Docker: o container alcança o Postgres do host via
# host.docker.internal. O docker-compose injeta este valor como DATABASE_URL.
DATABASE_URL_DOCKER="postgresql://portfolio:SENHA@host.docker.internal:5432/portfolio_dev?schema=public"

# Produção (Neon / Vercel Postgres) — use no painel da Vercel:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ---- NextAuth (Auth.js v5) --------------------------------------------------
# Gere um segredo forte com:  openssl rand -base64 32
NEXTAUTH_SECRET=""
# Dev: http://localhost:3000   |   Prod: https://SEU-APP.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---- Vercel Blob (upload de imagens) ----------------------------------------
# Painel Vercel > Storage > Blob > Tokens (funciona em dev e em produção)
BLOB_READ_WRITE_TOKEN=""

# ---- Admin inicial (usado APENAS pelo seed: prisma db seed) ------------------
ADMIN_EMAIL="14luisdias@gmail.com"
ADMIN_PASSWORD="troque-esta-senha-forte"

# ---- Contato / e-mail (Resend) — já existentes ------------------------------
# Sem a chave, o formulário continua funcionando e apenas registra nos logs.
RESEND_API_KEY=""
# Destino das mensagens do formulário (para onde os contatos são enviados).
CONTACT_EMAIL_TO="14luisdias@gmail.com"
# Remetente (from). Padrão do código: "Portfólio <onboarding@resend.dev>".
# O domínio onboarding@resend.dev só envia para o e-mail dono da conta Resend.
# Para usar um domínio próprio, verifique-o no Resend e defina abaixo, ex.:
# CONTACT_EMAIL_FROM="Portfólio <contato@seudominio.com>"
CONTACT_EMAIL_FROM=""
